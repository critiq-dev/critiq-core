{
  "name": "catalog",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/catalog/src",
  "projectType": "library",
  "tags": ["scope:oss-core", "type:core"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/catalog",
        "main": "libs/core/catalog/src/index.ts",
        "tsConfig": "libs/core/catalog/tsconfig.lib.json",
        "assets": ["libs/core/catalog/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --pretty false --noEmit -p libs/core/catalog/tsconfig.lib.json"
      }
    }
  }
}
