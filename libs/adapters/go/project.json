{
  "name": "go",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/adapters/go/src",
  "projectType": "library",
  "tags": ["scope:oss-core", "type:adapter"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/adapters/go",
        "main": "libs/adapters/go/src/index.ts",
        "tsConfig": "libs/adapters/go/tsconfig.lib.json",
        "assets": ["libs/adapters/go/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --pretty false --noEmit -p libs/adapters/go/tsconfig.lib.json"
      }
    }
  }
}
