{
  "name": "ruby",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/adapters/ruby/src",
  "projectType": "library",
  "tags": ["scope:oss-core", "type:adapter"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/adapters/ruby",
        "main": "libs/adapters/ruby/src/index.ts",
        "tsConfig": "libs/adapters/ruby/tsconfig.lib.json",
        "assets": ["libs/adapters/ruby/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --pretty false --noEmit -p libs/adapters/ruby/tsconfig.lib.json"
      }
    }
  }
}
